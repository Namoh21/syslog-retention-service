# Copy this file to .env and fill in your values

# ---- Required ----
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# ---- Claude AI (required for AI analysis) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Syslog listener ports ----
# Change if 514 conflicts or you need a non-privileged port (e.g. 5514)
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=514

# ---- Web API ----
API_HOST=0.0.0.0
API_PORT=8080

# ---- Retention ----
RETENTION_DAYS=90
MAX_LOG_ENTRIES=5000000

# ---- External API keys for Claude Projects / automated clients ----
# Comma-separated; generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
EXTERNAL_API_KEYS=

# ---- Claude model ----
CLAUDE_MODEL=claude-sonnet-4-6
