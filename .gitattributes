# Force LF line endings for all shell scripts and text files
# Prevents CRLF corruption when editing on Windows
*.sh    text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.html  text eol=lf
*.env   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.service text eol=lf
